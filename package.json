{
  "name": "engei",
  "version": "0.1.0",
  "description": "React code editor with inline comments, markdown preview, and extensible widgets. Built on CodeMirror 6.",
  "type": "module",
  "license": "MIT",
  "author": "Smithery",
  "repository": {
    "type": "git",
    "url": "https://github.com/smithery-ai/koen"
  },
  "homepage": "https://github.com/smithery-ai/koen",
  "keywords": [
    "react",
    "code-editor",
    "codemirror",
    "inline-comments",
    "markdown-preview",
    "editor",
    "codemirror-6"
  ],
  "main": "dist/engei.js",
  "module": "dist/engei.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/engei.js",
      "types": "./dist/index.d.ts"
    },
    "./styles": "./dist/engei.css"
  },
  "files": [
    "dist/engei.js",
    "dist/engei.css",
    "dist/index.d.ts",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": [
    "./dist/engei.js",
    "./dist/engei.css"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "deploy": "bun run build && wrangler deploy",
    "preview": "bun run build && wrangler dev"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/language": "^6.12.1",
    "@lezer/highlight": "^1.2.3",
    "boring-avatars": "^2.0.4",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "engei-widgets": "file:../engei-widgets",
    "marked": "^17.0.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.29.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^28.1.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.75.0"
  }
}
